# Server Configuration
# Port the HTTP server listens on
PORT=8080

# Logging Configuration
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log output format: text, json
LOG_OUTPUT=text

# Database Configuration
# Local SQLite file path, or a Turso/libSQL URL (libsql://<db>-<org>.turso.io)
DB_URL=./db.sqlite3

# Auth token for Turso/libSQL — only needed when DB_URL is a libsql:// URL
TURSO_AUTH_TOKEN=

# Rate Limiting Configuration
# Maximum requests per minute per IP address (default: 50)
RATE_LIMIT=50

# Development Notes:
# - Copy this file to .env and customize for your environment
# - .env is gitignored and should contain your local settings
# - Never commit secrets or credentials to version control
